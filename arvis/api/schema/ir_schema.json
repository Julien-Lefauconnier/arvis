{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARVIS IR v1",
  "type": "object",
  "required": [
    "version",
    "fingerprint",
    "input",
    "context",
    "decision",
    "state",
    "projection",
    "validity",
    "stability",
    "adaptive",
    "tools",
    "gate",
    "meta"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "fingerprint": {
      "type": "string"
    },
    "input": {
      "type": ["object", "null"]
    },
    "context": {
      "type": ["object", "null"]
    },
    "decision": {
      "type": ["object", "null"]
    },
    "state": {
      "type": ["object", "null"]
    },
    "projection": {
      "type": ["object", "null"]
    },
    "validity": {
      "type": ["object", "null"]
    },
    "stability": {
      "type": ["object", "null"]
    },
    "adaptive": {
      "type": ["object", "null"]
    },
    "tools": {
      "type": ["array", "object", "null"]
    },
    "gate": {
      "type": ["object", "null"]
    },
    "meta": {
      "type": "object",
      "properties": {
        "canonical_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": true
    }
  }
}
