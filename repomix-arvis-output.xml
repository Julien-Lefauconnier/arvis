def update_slow_state(
    z_prev: SlowState,
    T_x: Iterable[float],
    eta: float = 0.05,
) -> SlowState:
    prev = z_prev.as_vector()
    new = [(1.0 - eta) * p + eta * t for p, t in zip(prev, T_x, strict=True)]
    return SlowState(*new)
