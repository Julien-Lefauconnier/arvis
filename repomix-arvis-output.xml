name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  lint-and-type:
    runs-on: ubuntu-latest

    strategy:
      fail-fast: false
      matrix:
        python-version: ["3.11", "3.12", "3.13"]

    steps:
      - name: Checkout
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # v4

      - name: Setup Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5
        with:
          python-version: ${{ matrix.python-version }}
          cache: "pip"

      - name: Install deps
        run: |
          pip install --upgrade pip
          pip install -e .[dev] --prefer-binary

      - name: Fail on missing __all__
        run: python -c "import arvis; assert hasattr(arvis, '__all__') and arvis.__all__"

      - name: Ruff (lint)
        run: ruff check .

      - name: Ruff format check
        run: ruff format --check .

      - name: Mypy
        run: mypy arvis --strict

      - name: Dependency audit
        # Known vulnerabilities in the resolved dependency set. Advisory-only
        # for now: it reports without failing the job, so a fresh advisory on a
        # transitive dependency does not block unrelated work. Tighten to a
        # hard failure once the dev lockfile lands.
        run: |
          pip install pip-audit==2.10.1
          pip-audit --strict || echo "pip-audit reported findings (advisory)"

      - name: Bandit (medium/high)
        run: bash scripts/run_quality_gate.sh security

  test:
    runs-on: ubuntu-latest

    strategy:
      fail-fast: false
      matrix:
        python-version: ["3.11", "3.12", "3.13"]

    steps:
      - name: Checkout
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # v4

      - name: Setup Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5
        with:
          python-version: ${{ matrix.python-version }}
          cache: "pip"

      - name: Install deps
        run: |
          pip install --upgrade pip
          pip install -e .[dev] --prefer-binary

      - name: Run tests
        run: pytest --cov=arvis --cov-report=xml --cov-fail-under=90 --maxfail=1 --disable-warnings -q

      - name: Upload coverage to Codecov
        if: matrix.python-version == '3.11'
        uses: codecov/codecov-action@0fb7174895f61a3b6b78fc075e0cd60383518dac # v5

  smoke:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # v4

      - name: Setup Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install deps
        run: |
          pip install --upgrade pip
          pip install -e .[dev] --prefer-binary

      - name: Run examples smoke (stable examples)
        run: bash scripts/run_examples_smoke.sh

  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # v4

      - name: Setup Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install build tooling
        run: |
          pip install --upgrade pip
          pip install build twine

      - name: Build sdist and wheel
        run: python -m build

      - name: Twine metadata check
        run: twine check dist/*

      - name: Verify py.typed ships in the wheel
        run: python -c "import glob, zipfile; w = glob.glob('dist/*.whl')[0]; assert 'arvis/py.typed' in zipfile.ZipFile(w).namelist(), 'py.typed missing from wheel'; print('py.typed present in', w)"

      - name: Verify ir_schema.json ships in the wheel
        run: python -c "import glob, zipfile; w = glob.glob('dist/*.whl')[0]; assert 'arvis/api/schema/ir_schema.json' in zipfile.ZipFile(w).namelist(), 'ir_schema.json missing from wheel'; print('ir_schema.json present in', w)"

      - name: Reject forbidden wheel entries
        run: python scripts/check_wheel_contents.py dist/*.whl

      - name: Install built wheel in a clean env and smoke-import
        run: |
          python -m venv /tmp/wheelenv
          /tmp/wheelenv/bin/pip install --upgrade pip
          /tmp/wheelenv/bin/pip install "$(ls dist/*.whl)"
          cd /tmp
          /tmp/wheelenv/bin/python -c "import arvis; print('arvis', arvis.__version__); from arvis import ArvisEngine, CognitiveOS, CognitiveOSConfig; print('public API import OK')"
          /tmp/wheelenv/bin/python -c "import json; from importlib import resources; s = json.loads(resources.files('arvis.api').joinpath('schema/ir_schema.json').read_text(encoding='utf-8')); assert s.get('type') == 'object'; print('ir_schema.json loadable from installed wheel')"
