class FailingProvider(BaseLLMProvider):
    def generate(self, request: LLMRequest) -> LLMResponse:
        raise RuntimeError("boom")


class SuccessProvider(BaseLLMProvider):
    def generate(self, request: LLMRequest) -> LLMResponse:
