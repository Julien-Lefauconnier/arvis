from arvis.telemetry import TelemetryKind, TelemetryLevel
from arvis.telemetry.adapters import (
    ERROR_COMPONENT,
    degradation_event,
    error_event,
    escalation_event,
)


def test_escalation_event_carries_counters() -> None:
