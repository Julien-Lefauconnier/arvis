        class Cert:
            domain_valid = True
            margin_to_boundary = 1.0
            certification_level = type("L", (), {"value": "FULL"})()
            lyapunov_compatibility_ok = True
            is_projection_safe = True

        return Cert()


def test_projection_stage_applies_pi_operator():
