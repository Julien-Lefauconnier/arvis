<file path=".github/workflows/release.yml">
name: release

on:
  push:
    # Version tags only. The exact tag/version equality is enforced in the
    # verify job; this pattern merely keeps unrelated tags from starting a
    # release run at all.
    tags:
      - "v[0-9]+.[0-9]+.[0-9]+*"

# Least privilege by default: no job may write to the repository. The publish
# job alone raises id-token, and only because OIDC Trusted Publishing needs it.
permissions:
  contents: read

jobs:
  verify:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      # Provenance attestation is signed here, where the artifacts are built
      # and verified, not in the publish job which only forwards them.
      id-token: write
      attestations: write

    steps:
      - name: Checkout
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # v4

      - name: Setup Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Verify the tag names the packaged version
        # A tag that does not match the packaged version would publish a
        # release whose number means nothing. Fail before anything is built.
        run: |
          package_version="$(python - <<'PY'
          import tomllib
          from pathlib import Path

          data = tomllib.loads(Path("pyproject.toml").read_text(encoding="utf-8"))
          print(data["project"]["version"])
          PY
          )"
          echo "tag=${GITHUB_REF_NAME} package=${package_version}"
          test "${GITHUB_REF_NAME}" = "v${package_version}"

      - name: Verify the changelog documents this version
        # A release nobody can read the history of is not a release.
        run: |
          package_version="${GITHUB_REF_NAME#v}"
          grep -q "^## \[${package_version}\]" CHANGELOG.md

      - name: Install the package and its development tooling
        run: |
          python -m pip install --upgrade pip
          pip install -e ".[dev]"

      - name: Quality gate
        # The same gate contributors run: format, lint, mypy strict, bandit,
        # coverage floor, examples smoke. A release must not lower the bar the
        # main branch already meets.
        run: bash scripts/run_quality_gate.sh all

      - name: Install build tooling
        # Pinned: the artifact that reaches PyPI must not depend on whichever
        # builder happened to be current that day.
        run: pip install build==1.5.0 twine==6.2.0 cyclonedx-bom==7.3.1

      - name: Build sdist and wheel
        run: python -m build

      - name: Twine metadata check
        run: twine check dist/*

      - name: Reject forbidden wheel entries
        run: python scripts/check_wheel_contents.py dist/*.whl

      - name: Install the built wheel in a clean env and smoke-import
        run: |
          python -m venv /tmp/wheelenv
          /tmp/wheelenv/bin/pip install --upgrade pip
          /tmp/wheelenv/bin/pip install "$(ls dist/*.whl)"
          cd /tmp
          /tmp/wheelenv/bin/python -c "import arvis; print('arvis', arvis.__version__); from arvis import ArvisEngine, CognitiveOS, CognitiveOSConfig; print('public API import OK')"

      - name: Generate the SBOM
        # Describes what the built environment actually contains, so a consumer
        # can answer "is this release affected by X" without guessing.
        #
        # Written OUTSIDE dist/: the publish job forwards that directory to
        # PyPI wholesale, and an SBOM is not a distribution file.
        run: |
          mkdir -p sbom
          cyclonedx-py environment \
            --output-format json \
            --outfile sbom/arvis-sbom.json

      - name: Upload the SBOM
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: sbom
          path: sbom/
          if-no-files-found: error

      - name: Attest the build provenance
        # Signs a statement tying these exact artifacts to this workflow run,
        # verifiable with: gh attestation verify <file> --repo <owner>/<repo>
        uses: actions/attest-build-provenance@e8998f949152b193b063cb0ec769d69d929409be # v2
        with:
          subject-path: "dist/*.whl,dist/*.tar.gz"

      - name: Upload the verified artifacts
        # What gets published is what was verified here, byte for byte. A
        # rebuild in the publish job would ship an artifact nothing checked.
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: dist
          path: dist/
          if-no-files-found: error
          retention-days: 1

  publish:
    needs: verify
    runs-on: ubuntu-latest
    environment: pypi
    permissions:
      contents: read
      id-token: write

    steps:
      - name: Download the verified artifacts
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: dist
          path: dist/

      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@ba38be9e461d3875417946c167d0b5f3d385a247 # release/v1
</file>

