# --------------------------------------------------


class Exploding:
    def compute(self, *a, **kw):
        raise RuntimeError("boom")

    def update(self, *a, **kw):
        raise RuntimeError("boom")

    def evaluate(self, *a, **kw):
        raise RuntimeError("boom")

    def push(self, *a, **kw):
        raise RuntimeError("boom")


